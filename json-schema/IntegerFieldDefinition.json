{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-evangelist.github.io/benchling/json-schema/IntegerFieldDefinition.json",
  "title": "IntegerFieldDefinition",
  "allOf": [
    {
      "$ref": "#/components/schemas/FieldDefinition"
    },
    {
      "properties": {
        "numericMax": {
          "nullable": true,
          "type": "number"
        },
        "numericMin": {
          "nullable": true,
          "type": "number"
        },
        "type": {
          "enum": [
            "integer"
          ],
          "type": "string"
        },
        "unit": {
          "allOf": [
            {
              "$ref": "#/components/schemas/UnitSummary"
            }
          ],
          "nullable": true
        }
      },
      "type": "object"
    }
  ]
}