{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-evangelist.github.io/benchling/json-schema/TokenResponse.json",
  "title": "TokenResponse",
  "properties": {
    "access_token": {
      "example": "eyJ...",
      "type": "string"
    },
    "expires_in": {
      "description": "Number of seconds that token is valid for",
      "example": 900,
      "type": "integer"
    },
    "token_type": {
      "enum": [
        "Bearer"
      ],
      "example": "Bearer",
      "type": "string"
    }
  },
  "type": "object"
}