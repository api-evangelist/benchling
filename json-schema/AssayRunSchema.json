{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-evangelist.github.io/benchling/json-schema/AssayRunSchema.json",
  "title": "AssayRunSchema",
  "allOf": [
    {
      "$ref": "#/components/schemas/BaseAssaySchema"
    },
    {
      "properties": {
        "automationInputFileConfigs": {
          "items": {
            "properties": {
              "name": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "type": "array"
        },
        "automationOutputFileConfigs": {
          "items": {
            "properties": {
              "name": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "type": "array"
        },
        "modifiedAt": {
          "description": "DateTime the Assay Run Schema was last modified",
          "example": "2017-04-18T05:55:48.685345+00:00",
          "format": "date-time",
          "type": "string"
        },
        "type": {
          "enum": [
            "assay_run"
          ],
          "readOnly": true,
          "type": "string"
        }
      },
      "type": "object"
    }
  ]
}