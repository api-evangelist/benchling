{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-evangelist.github.io/benchling/json-schema/Primer.json",
  "title": "Primer",
  "properties": {
    "bases": {
      "readOnly": true,
      "type": "string"
    },
    "bindPosition": {
      "readOnly": true,
      "type": "integer"
    },
    "color": {
      "readOnly": true,
      "type": "string"
    },
    "end": {
      "description": "0-based exclusive end index. The end of the sequence is always represented as 0.",
      "type": "integer"
    },
    "name": {
      "readOnly": true,
      "type": "string"
    },
    "oligoId": {
      "type": "string"
    },
    "overhangLength": {
      "readOnly": true,
      "type": "integer"
    },
    "start": {
      "description": "0-based inclusive start index.",
      "type": "integer"
    },
    "strand": {
      "example": 1,
      "type": "integer"
    }
  },
  "type": "object"
}