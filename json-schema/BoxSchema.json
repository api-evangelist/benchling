{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-evangelist.github.io/benchling/json-schema/BoxSchema.json",
  "title": "BoxSchema",
  "allOf": [
    {
      "$ref": "#/components/schemas/RegistrySchema"
    },
    {
      "properties": {
        "containerSchema": {
          "nullable": true,
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "height": {
          "type": "number"
        },
        "modifiedAt": {
          "description": "DateTime the Box Schema was last modified",
          "example": "2017-04-18T05:55:48.685345+00:00",
          "format": "date-time",
          "type": "string"
        },
        "type": {
          "enum": [
            "box"
          ],
          "readOnly": true,
          "type": "string"
        },
        "width": {
          "type": "number"
        }
      },
      "type": "object"
    }
  ]
}