  "$id": "https://api-evangelist.github.io/benchling/json-schema/OAuthBadRequestError.json",
  "title": "OAuthBadRequestError",
  "properties": {
    "error": {
      "allOf": [
        {
          "$ref": "#/components/schemas/BaseError"
        },
        {
          "properties": {
