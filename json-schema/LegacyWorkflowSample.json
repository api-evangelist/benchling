{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-evangelist.github.io/benchling/json-schema/LegacyWorkflowSample.json",
  "title": "LegacyWorkflowSample",
  "properties": {
    "batchId": {
      "description": "ID of the batch",
      "type": "string"
    },
    "containerIds": {
      "description": "Array of IDs of containers",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "createdAt": {
      "description": "DateTime at which the the sample was created",
      "format": "date-time",
      "readOnly": true,
      "type": "string"
    },
    "id": {
      "description": "ID of the sample",
      "readOnly": true,
      "type": "string"
    },
    "name": {
      "description": "Name of the sample",
      "type": "string"
    }
  },
  "type": "object"
}