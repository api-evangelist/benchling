{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-evangelist.github.io/benchling/json-schema/RnaAnnotation.json",
  "title": "RnaAnnotation",
  "allOf": [
    {
      "$ref": "#/components/schemas/SequenceFeatureBase"
    },
    {
      "properties": {
        "end": {
          "description": "0-based exclusive end index. The end of the sequence is always represented as 0.",
          "type": "integer"
        },
        "start": {
          "description": "0-based inclusive start index.",
          "type": "integer"
        },
        "strand": {
          "example": 1,
          "maximum": 1,
          "minimum": 0,
          "type": "integer"
        },
        "type": {
          "type": "string"
        }
      },
      "type": "object"
    }
  ]
}