{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-evangelist.github.io/benchling/json-schema/NucleotideSequencePart.json",
  "title": "NucleotideSequencePart",
  "properties": {
    "end": {
      "description": "0-based exclusive end index. The end of the sequence is always represented as 0.",
      "type": "integer"
    },
    "sequenceId": {
      "example": "seq_VfVOART1",
      "type": "string"
    },
    "start": {
      "description": "0-based inclusive start index.",
      "type": "integer"
    }
  },
  "type": "object"
}