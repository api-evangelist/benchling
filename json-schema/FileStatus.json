{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-evangelist.github.io/benchling/json-schema/FileStatus.json",
  "title": "FileStatus",
  "properties": {
    "errorMessage": {
      "example": null,
      "nullable": true,
