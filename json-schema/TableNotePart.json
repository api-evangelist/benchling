{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-evangelist.github.io/benchling/json-schema/TableNotePart.json",
  "title": "TableNotePart",
  "allOf": [
    {
      "$ref": "#/components/schemas/BaseNotePart"
    },
    {
      "properties": {
        "links": {
          "description": "Array of links referenced in the caption via an @-mention, hyperlink, or the drag-n-dropped preview attached to the note.\n",
          "items": {
            "$ref": "#/components/schemas/EntryLink"
          },
          "type": "array"
        },
        "table": {
          "allOf": [
            {
              "$ref": "#/components/schemas/EntryTable"
            }
          ],
          "type": "object"
        },
        "text": {
          "description": "The caption of the table.",
          "type": "string"
        },
        "type": {
          "enum": [
            "table"
          ],
          "type": "string"
        }
      },
      "type": "object"
    }
  ],
  "description": "A table with rows and columns of text"
}